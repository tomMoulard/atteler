/atteler
/symphony
/dist

# Atteler repository-local state is private/generated by default.
# See .atteler/README.md for the artifact taxonomy and review checklist.
!/.atteler/
/.atteler/*
!/.atteler/README.md

# Reviewable project assets: intentionally curated and redacted.
!/.atteler/fixtures/
/.atteler/fixtures/*
!/.atteler/fixtures/README.md
!/.atteler/fixtures/**/
!/.atteler/fixtures/**/*.fixture.json
!/.atteler/fixtures/**/*.fixture.yaml
!/.atteler/fixtures/**/*.fixture.yml

!/.atteler/evals/
/.atteler/evals/*
!/.atteler/evals/README.md
!/.atteler/evals/**/
!/.atteler/evals/**/*.eval.json
!/.atteler/evals/**/*.eval.yaml
!/.atteler/evals/**/*.eval.yml

!/.atteler/skills/
/.atteler/skills/*
!/.atteler/skills/README.md
!/.atteler/skills/curated/
!/.atteler/skills/curated/**

# Adjacent Atteler state/temp files can appear when ATTELER_STATE points at the repo.
/.atteler-state*
/.atteler-config-*.tmp

# Nested/generated Atteler stores that can appear below package working dirs.
**/.atteler/workspace-vector-index*.json
**/.atteler/workspace-index*.json
**/.atteler/codeintel-index*.json
**/.atteler/agent-memory.json
**/.atteler/session-vector-index*.json
**/.atteler/git-history-vector-index*.json
**/.atteler/adr-vector-index*.json
**/.atteler/vector-index*.json
**/.atteler/.agent-memory-*.tmp
**/.atteler/.vector-index-*.tmp
**/.atteler/.vector-store-*.tmp
**/.atteler/.state-*.json
cmd/atteler/.atteler/
/.symphony/workspaces/

